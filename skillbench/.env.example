# ============================================================
# API Keys for various LLM providers
# ============================================================

# OpenRouter API Key (used by default)
# Supports: openrouter/deepseek/deepseek-v3.2 and other OpenRouter models
OPENROUTER_API_KEY=

# Optional: Direct provider API Keys (if using direct model calls)
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# TOGETHER_API_KEY=
# OPENCODE_API_KEY=

# Model configuration
# Default: openrouter/deepseek/deepseek-v3.2
# Other options:
# - openrouter/openai/gpt-4o
# - openrouter/anthropic/claude-3.5-sonnet
# - deepseek/deepseek-v3.2 (requires DEEPSEEK_API_KEY)
# - gpt-4o (requires OPENAI_API_KEY)
# - claude-3.5-sonnet (requires ANTHROPIC_API_KEY)
MODEL=

# Skill Insight Dashboard URL
SKILL_INSIGHT_BASE_URL=http://localhost:3000

GITHUB_TOKEN=
# ============================================================
# Pipeline configuration (defaults for run_pipeline.sh)
# ============================================================
START_STEP=1
END_STEP=6

TASKS_INIT_DIR=${BASE_DIR}/tasks_init

MODES="dynamic"

AGENT="opencode"

#Step 1, 6
MAX_PARALLEL=3
RUNS=1